---
import { Icon } from "astro-icon/components";

import { galleryPhotos } from "../../../data/gallery";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import type { TimelineCardProps } from "./types";

const { item } = Astro.props as TimelineCardProps;

const isCurrent = !item.endDate || new Date(item.endDate) >= new Date();

const getTypeIcon = (type: string) => {
	switch (type) {
		case "internship":
			return "material-symbols:work";
		case "competition":
			return "material-symbols:emoji-events";
		case "project":
			return "material-symbols:code";
		case "lab":
			return "material-symbols:science";
		default:
			return "material-symbols:event";
	}
};

const getTypeText = (type: string) => {
	switch (type) {
		case "internship":
			return "实习";
		case "competition":
			return "竞赛";
		case "project":
			return "项目";
		case "lab":
			return "实验室";
		default:
			return type;
	}
};

const getLinkIcon = (type: string) => {
	switch (type) {
		case "certificate":
			return "material-symbols:verified";
		case "project":
			return "material-symbols:open-in-new";
		case "website":
			return "material-symbols:language";
		default:
			return "material-symbols:description";
	}
};

const getPhotoLinkIcon = (type: string) => {
	switch (type) {
		case "博客":
			return "material-symbols:article";
		case "项目":
			return "material-symbols:work";
		case "经验":
			return "material-symbols:psychology-alt-rounded";
		case "说说":
			return "material-symbols:forum";
		default:
			return "material-symbols:link-rounded";
	}
};

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleDateString("zh-CN", {
		year: "numeric",
		month: "short",
	});
};

const getDuration = (startDate: string, endDate?: string) => {
	const start = new Date(startDate);
	const end = endDate ? new Date(endDate) : new Date();
	const diffTime = Math.abs(end.getTime() - start.getTime());
	const diffMonths = Math.ceil(diffTime / (1000 * 60 * 60 * 24 * 30));

	if (diffMonths < 12) {
		return `${diffMonths} ${i18n(I18nKey.timelineMonths)}`;
	}
	const years = Math.floor(diffMonths / 12);
	const months = diffMonths % 12;
	if (months === 0) {
		return `${years} ${i18n(I18nKey.timelineYears)}`;
	}
	return `${years} ${i18n(I18nKey.timelineYears)} ${months} ${i18n(I18nKey.timelineMonths)}`;
};

const icon = item.icon || getTypeIcon(item.type);
const typeText = getTypeText(item.type);
const dateRange =
	item.dateDisplay ||
	`${formatDate(item.startDate)} - ${item.endDate ? formatDate(item.endDate) : i18n(I18nKey.timelinePresent)}`;
const duration = item.durationDisplay || getDuration(item.startDate, item.endDate);
const nodeColor = isCurrent ? "#22c55e" : item.color || "var(--primary)";
const hasLinks = item.links && item.links.length > 0;
const hasProjects = item.projects && item.projects.length > 0;
const timelineHref = `/timeline/#${item.id}`;
const itemPhotos = galleryPhotos.filter((photo) =>
	photo.links.some((link) => link.href === timelineHref),
);
const getAlbumGroupHref = (photoId: string) =>
	`/albums/?timeline=${encodeURIComponent(item.id)}#${photoId}`;
const getPhotoLinks = (photo: (typeof galleryPhotos)[number]) =>
	photo.links.filter((link) => link.href !== timelineHref).slice(0, 4);
const minTimelineTrackPhotoCount = 5;
const timelineTrackPhotos =
	itemPhotos.length === 0
		? []
		: Array.from(
				{ length: Math.max(itemPhotos.length, minTimelineTrackPhotoCount) },
				(_, index) => itemPhotos[index % itemPhotos.length],
			);
---

<div
	id={item.id}
	class:list={["timeline-entry", { "is-current": isCurrent }]}
	data-type={item.type}
>
	<div class="timeline-node" style={`background-color: ${nodeColor};`}>
		<Icon name={icon} class="w-2.5 h-2.5" style="color: white;" />
	</div>

	<div
		class="timeline-card group relative rounded-xl border border-black/10 dark:border-white/10 overflow-hidden transition-all duration-300 hover:shadow-lg"
	>
		<div class="p-5 sm:p-6">
			<div class="flex items-start gap-3 mb-3">
				<div
					class="w-10 h-10 shrink-0 rounded-lg flex items-center justify-center bg-(--btn-regular-bg)"
				>
					<Icon
						name={icon}
						class="text-lg"
						style={`color: ${item.color || "var(--primary)"};`}
					/>
				</div>

				<div class="flex-1 min-w-0">
					<div class="flex items-center gap-2 mb-0.5">
						<h3
							class="text-lg font-bold text-black/90 dark:text-white/90 group-hover:text-(--primary) transition-colors duration-200"
						>
							{item.title}
						</h3>
						{
							item.featured && (
								<Icon
									name="material-symbols:star-rounded"
									class="text-base w-4 h-4 text-(--primary) shrink-0"
								/>
							)
						}
					</div>
					{
						item.organization && (
							<p class="text-sm text-black/60 dark:text-white/60">
								{item.organization}
								{item.position ? ` · ${item.position}` : ""}
							</p>
						)
					}
				</div>

				<div class="flex items-center gap-1.5 shrink-0 ml-2">
					{
						isCurrent && (
							<span class="px-2 py-0.5 text-xs rounded-md bg-green-500/10 text-green-600 dark:text-green-400 font-medium">
								{i18n(I18nKey.timelineCurrent)}
							</span>
						)
					}
					<span
						class="px-2 py-0.5 text-xs rounded-md bg-(--primary)/10 text-(--primary) font-medium"
					>
						{typeText}
					</span>
				</div>
			</div>

			<p
				class="text-sm text-black/70 dark:text-white/70 mb-4 leading-relaxed"
			>
				{item.description}
			</p>

			{
				itemPhotos.length > 0 && (
					<div
						class="timeline-photo-strip"
						aria-label={`${item.title}照片预览`}
					>
						<div class="timeline-photo-track">
							{[0, 1].map((loopIndex) => (
								<div
									class="timeline-photo-loop"
									aria-hidden={loopIndex === 1 ? "true" : undefined}
								>
									{timelineTrackPhotos.map((photo) => (
								<div
									class="timeline-photo-frame"
									style={`--timeline-photo-accent: ${photo.accent ?? item.color ?? "var(--primary)"};`}
								>
									<a
										href={getAlbumGroupHref(photo.id)}
										class="timeline-photo-cover"
										tabindex={loopIndex === 1 ? "-1" : undefined}
										aria-label={`查看相册分组：${photo.title}`}
									>
										<picture>
											{photo.image?.sources?.map((source) => (
												<source
													type={source.type}
													srcset={source.srcset}
													sizes={photo.image?.sizes}
												/>
											))}
											<img
												src={photo.image?.src ?? photo.src}
												alt={photo.alt}
												loading="lazy"
												decoding="async"
												sizes={photo.image?.sizes}
												width={photo.image?.width}
												height={photo.image?.height}
											/>
										</picture>
										<span class="timeline-photo-title">{photo.title}</span>
									</a>
									<div class="timeline-photo-links">
										{getPhotoLinks(photo).map((link) => (
											<a
												href={link.href}
												class="timeline-photo-link"
												tabindex={loopIndex === 1 ? "-1" : undefined}
											>
												<Icon
													name={getPhotoLinkIcon(link.type)}
													class="h-3 w-3 shrink-0"
												/>
												<span>{link.type}</span>
											</a>
										))}
									</div>
								</div>
									))}
								</div>
							))}
						</div>
					</div>
				)
			}

			{
				item.skills && item.skills.length > 0 && (
					<div class="flex flex-wrap gap-2 mb-4">
						{item.skills.map((skill) => (
							<span class="px-2 py-1 text-xs rounded-md bg-(--primary)/10 text-(--primary) font-medium">
								{skill}
							</span>
						))}
					</div>
				)
			}

			{
				hasProjects && (
					<div class="mb-4">
						<h4 class="text-xs font-semibold text-black/50 dark:text-white/50 uppercase tracking-wider mb-2">
							关联项目
						</h4>
						<div class="space-y-3">
							{item.projects!.map((project) => (
								<div class="border-l-2 border-(--primary)/40 pl-3">
									<div class="flex items-start gap-2">
										<Icon
											name="material-symbols:subdirectory-arrow-right-rounded"
											class="mt-0.5 h-4 w-4 shrink-0 text-(--primary)"
										/>
										<div class="min-w-0">
											{
												project.url ? (
													<a
														href={project.url}
														class="text-sm font-semibold text-black/80 dark:text-white/80 hover:text-(--primary) transition-colors"
													>
														{project.name}
													</a>
												) : (
													<div class="text-sm font-semibold text-black/80 dark:text-white/80">
														{project.name}
													</div>
												)
											}
											<p class="mt-1 text-sm leading-relaxed text-black/60 dark:text-white/60">
												{project.summary}
											</p>
										</div>
									</div>
								</div>
							))}
						</div>
					</div>
				)
			}

			{
				item.achievements && item.achievements.length > 0 && (
					<div class="mb-4">
						<h4 class="text-xs font-semibold text-black/50 dark:text-white/50 uppercase tracking-wider mb-2">
							成果
						</h4>
						<ul class="space-y-1.5">
							{item.achievements.map((achievement) => (
								<li class="text-sm text-black/70 dark:text-white/70 flex items-start gap-2">
									<Icon
										name="material-symbols:check-circle"
										class="text-base w-4 h-4 text-green-500 shrink-0 mt-0.5"
									/>
									<span>{achievement}</span>
								</li>
							))}
						</ul>
					</div>
				)
			}

			<div
				class="flex items-center gap-4 text-xs text-black/50 dark:text-white/50 mb-1 pt-3 border-t border-black/5 dark:border-white/5"
			>
				<span class="flex items-center gap-1">
					<Icon
						name="material-symbols:calendar-month-outline"
						class="text-xs w-3.5 h-3.5"
					/>
					{dateRange}
				</span>
				<span class="flex items-center gap-1">
					<Icon
						name="material-symbols:schedule-outline"
						class="text-xs w-3.5 h-3.5"
					/>
					{duration}
				</span>
				{
					item.location && (
						<span class="flex items-center gap-1">
							<Icon
								name="material-symbols:location-on-outline"
								class="text-xs w-3.5 h-3.5"
							/>
							{item.location}
						</span>
					)
				}
			</div>

			{
				hasLinks && (
					<div class="flex flex-wrap gap-2 mt-3">
						{item.links!.map((link) => (
							<a
								href={link.url}
								target="_blank"
								rel="noopener noreferrer"
								class="btn-regular flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium"
							>
								<Icon
									name={getLinkIcon(link.type)}
									class="text-xs w-3.5 h-3.5"
								/>
								{link.name}
							</a>
						))}
					</div>
				)
			}
		</div>

		<div
			class="absolute inset-0 bg-linear-to-br from-(--primary)/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-xl"
		>
		</div>
	</div>
</div>

<style>
	.timeline-entry {
		position: relative;
		padding-left: 2.5rem;
		padding-bottom: 2rem;
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
		scroll-margin-top: 6rem;
	}

	.timeline-entry:last-child {
		padding-bottom: 0;
	}

	.timeline-entry.filtered-out {
		display: none;
	}

	.timeline-photo-strip {
		position: relative;
		margin: -0.1rem 0 1rem;
		padding: 0.95rem 0.8rem;
		overflow: hidden;
		border: 1px solid color-mix(in srgb, var(--primary) 18%, transparent);
		border-radius: 0.95rem;
		background:
			repeating-linear-gradient(
				90deg,
				rgb(15 23 42 / 0.18) 0 0.36rem,
				transparent 0.36rem 0.72rem
			) top 0.34rem left 0.85rem / calc(100% - 1.7rem) 0.28rem no-repeat,
			repeating-linear-gradient(
				90deg,
				rgb(15 23 42 / 0.18) 0 0.36rem,
				transparent 0.36rem 0.72rem
			) bottom 0.34rem left 0.85rem / calc(100% - 1.7rem) 0.28rem no-repeat,
			linear-gradient(135deg, rgb(15 23 42 / 0.055), transparent 58%),
			color-mix(in srgb, var(--btn-regular-bg) 88%, transparent);
	}

	:global(.dark) .timeline-photo-strip {
		background:
			repeating-linear-gradient(
				90deg,
				rgb(255 255 255 / 0.22) 0 0.36rem,
				transparent 0.36rem 0.72rem
			) top 0.34rem left 0.85rem / calc(100% - 1.7rem) 0.28rem no-repeat,
			repeating-linear-gradient(
				90deg,
				rgb(255 255 255 / 0.18) 0 0.36rem,
				transparent 0.36rem 0.72rem
			) bottom 0.34rem left 0.85rem / calc(100% - 1.7rem) 0.28rem no-repeat,
			linear-gradient(135deg, rgb(255 255 255 / 0.08), transparent 58%),
			color-mix(in srgb, var(--btn-regular-bg) 88%, transparent);
	}

	.timeline-photo-track {
		display: flex;
		width: max-content;
		max-width: none;
		padding: 0.4rem 0.15rem 0.5rem;
		animation: timelineFilmScroll 34s linear infinite;
		will-change: transform;
	}

	.timeline-photo-strip:hover .timeline-photo-track,
	.timeline-photo-strip:focus-within .timeline-photo-track {
		animation-play-state: paused;
	}

	.timeline-photo-loop {
		display: flex;
		flex: 0 0 auto;
		gap: 0.75rem;
		padding-right: 0.75rem;
	}

	.timeline-photo-frame {
		position: relative;
		display: flex;
		width: 10.8rem;
		flex: 0 0 10.8rem;
		flex-direction: column;
		scroll-snap-align: start;
		border: 1px solid color-mix(in srgb, var(--timeline-photo-accent) 28%, transparent);
		border-radius: 0.78rem;
		background: color-mix(in srgb, var(--card-bg) 92%, transparent);
		box-shadow: 0 10px 22px rgb(15 23 42 / 0.1);
		transition:
			transform 0.26s ease,
			box-shadow 0.26s ease,
			border-color 0.26s ease;
	}

	.timeline-photo-cover {
		position: relative;
		display: block;
		overflow: hidden;
		aspect-ratio: 4 / 3;
		border-radius: 0.72rem 0.72rem 0.45rem 0.45rem;
		text-decoration: none;
	}

	.timeline-photo-cover picture {
		display: block;
		width: 100%;
		height: 100%;
	}

	.timeline-photo-cover img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition:
			transform 0.45s cubic-bezier(0.22, 1, 0.36, 1),
			filter 0.24s ease;
	}

	.timeline-photo-cover::after {
		content: "";
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, transparent 40%, rgb(0 0 0 / 0.68)),
			linear-gradient(135deg, color-mix(in srgb, var(--timeline-photo-accent) 18%, transparent), transparent 56%);
		pointer-events: none;
	}

	.timeline-photo-title {
		position: absolute;
		right: 0.55rem;
		bottom: 0.48rem;
		left: 0.55rem;
		z-index: 1;
		overflow: hidden;
		color: white;
		font-size: 0.72rem;
		font-weight: 750;
		line-height: 1.25;
		text-overflow: ellipsis;
		text-shadow: 0 1px 8px rgb(0 0 0 / 0.45);
		white-space: nowrap;
	}

	.timeline-photo-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.34rem;
		padding: 0.48rem;
	}

	.timeline-photo-link {
		display: inline-flex;
		min-width: 0;
		align-items: center;
		gap: 0.25rem;
		padding: 0.26rem 0.4rem;
		border-radius: 0.48rem;
		background: color-mix(in srgb, var(--timeline-photo-accent) 10%, var(--btn-regular-bg));
		color: color-mix(in srgb, var(--timeline-photo-accent) 70%, rgb(0 0 0) 30%);
		font-size: 0.68rem;
		font-weight: 700;
		text-decoration: none;
	}

	:global(.dark) .timeline-photo-link {
		color: color-mix(in srgb, var(--timeline-photo-accent) 72%, rgb(255 255 255) 28%);
	}

	.timeline-photo-link:hover {
		background: color-mix(in srgb, var(--timeline-photo-accent) 18%, var(--btn-regular-bg));
	}

	@media (hover: hover) and (pointer: fine) {
		.timeline-photo-frame:hover {
			z-index: 4;
			transform: translateY(-0.28rem) scale(1.08);
			border-color: color-mix(in srgb, var(--timeline-photo-accent) 58%, transparent);
			box-shadow:
				0 18px 34px rgb(15 23 42 / 0.18),
				0 0 0 1px color-mix(in srgb, var(--timeline-photo-accent) 18%, transparent);
		}

		.timeline-photo-frame:hover img {
			transform: scale(1.06);
			filter: saturate(1.08) contrast(1.03);
		}
	}

	@media (width < 640px) {
		.timeline-photo-strip {
			margin-right: -0.15rem;
			margin-left: -0.15rem;
			padding: 0.8rem 0.65rem;
			border-radius: 0.82rem;
		}

		.timeline-photo-track {
			padding-bottom: 0.35rem;
			animation-duration: 28s;
		}

		.timeline-photo-loop {
			gap: 0.62rem;
			padding-right: 0.62rem;
		}

		.timeline-photo-frame {
			width: 12.2rem;
			flex-basis: 12.2rem;
		}
	}

	.timeline-node {
		position: absolute;
		left: 0;
		top: 1.5rem;
		width: 1.25rem;
		height: 1.25rem;
		border-radius: 50%;
		border: 2.5px solid white;
		box-shadow: 0 0 0 2px var(--line-divider);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 2;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.timeline-entry:hover .timeline-node {
		transform: scale(1.15);
		box-shadow:
			0 0 0 2px var(--primary),
			0 0 12px rgba(0, 0, 0, 0.1);
	}

	.timeline-entry.is-current .timeline-node {
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes timelineFilmScroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}

	@keyframes pulse {
		0%,
		100% {
			box-shadow: 0 0 0 2px var(--line-divider);
		}
		50% {
			box-shadow:
				0 0 0 2px #22c55e,
				0 0 8px rgba(34, 197, 94, 0.3);
		}
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(16px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.timeline-entry:nth-child(1) {
		animation-delay: 0.05s;
	}
	.timeline-entry:nth-child(2) {
		animation-delay: 0.1s;
	}
	.timeline-entry:nth-child(3) {
		animation-delay: 0.15s;
	}
	.timeline-entry:nth-child(4) {
		animation-delay: 0.2s;
	}
	.timeline-entry:nth-child(5) {
		animation-delay: 0.25s;
	}
	.timeline-entry:nth-child(6) {
		animation-delay: 0.3s;
	}
	.timeline-entry:nth-child(7) {
		animation-delay: 0.35s;
	}
	.timeline-entry:nth-child(8) {
		animation-delay: 0.4s;
	}
	.timeline-entry:nth-child(9) {
		animation-delay: 0.45s;
	}
</style>
