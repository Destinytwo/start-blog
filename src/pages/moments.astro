---
import { MomentCard } from "@components/features/moments";
import { PageHeader } from "@components/features/page-header";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

import { momentsConfig, siteConfig } from "../config";
import { getMomentsList } from "../data/moments";

if (!siteConfig.featurePages.moments) {
	return Astro.redirect("/404/");
}

const moments = getMomentsList();
const title = "说说";
const subtitle = "记录一些短想法、当日状态和不需要写成长文的小片段。";
const gitalkConfig = momentsConfig.comments.gitalk;
const commentsEnabled =
	momentsConfig.comments.enable && momentsConfig.comments.provider === "gitalk";
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
		import { loadIconify } from "../utils/icon-loader";

		loadIconify().catch((error) => {
			console.error("Failed to load Iconify:", error);
		});
	</script>

	<div
		class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
				<PageHeader title={title} subtitle={subtitle} class="mb-0" />

				<div
					class="shrink-0 inline-flex items-center gap-2 rounded-lg border border-black/10 dark:border-white/10 bg-(--btn-regular-bg) px-3 py-2 text-sm text-black/65 dark:text-white/65"
				>
					<Icon
						name="material-symbols:forum"
						class="h-4 w-4 text-(--primary)"
					/>
					<span>{moments.length} 条</span>
				</div>
			</div>

			<div
				class="mt-8 flex flex-wrap items-center justify-between gap-3 border-y border-black/10 dark:border-white/10 py-4"
			>
				<div class="text-sm text-black/50 dark:text-white/50">
					按时间浏览
				</div>
				<div class="flex gap-2" id="moments-sort-controls">
					<button
						type="button"
						class="moments-sort-btn btn-regular active rounded-lg px-3 py-2 text-sm font-medium"
						data-sort="desc"
					>
						最新
					</button>
					<button
						type="button"
						class="moments-sort-btn btn-regular rounded-lg px-3 py-2 text-sm font-medium"
						data-sort="asc"
					>
						最早
					</button>
				</div>
			</div>

			<div id="moments-list" class="mt-6 space-y-5">
				{
					moments.map((moment, index) => (
						<MomentCard
							moment={moment}
							index={index}
							commentsEnabled={commentsEnabled}
						/>
					))
				}
			</div>

			{
				moments.length === 0 && (
					<div class="py-16 text-center">
						<Icon
							name="material-symbols:edit-note"
							class="mb-4 text-6xl text-black/15 dark:text-white/15"
						/>
						<p class="text-lg text-black/40 dark:text-white/40">
							还没有说说
						</p>
					</div>
				)
			}
		</div>
	</div>

	<script
		is:inline
		define:vars={{
			commentsEnabled,
			gitalkConfig,
		}}
	>
		(function () {
			const COMMENT_SELECTOR = ".gitalk-comments";
			const GITALK_CSS_ID = "gitalk-css";
			const GITALK_SCRIPT_ID = "gitalk-script";
			let gitalkScriptPromise = null;

			function getTheme() {
				const isDark =
					document.documentElement.classList.contains("dark") ||
					document.documentElement
						.getAttribute("data-theme")
						?.includes("dark");
				return isDark ? "dark" : "light";
			}

			function hasGitalkCredentials() {
				return Boolean(gitalkConfig.clientID && gitalkConfig.clientSecret);
			}

			function showConfigWarning(container) {
				container.innerHTML =
					'<div class="rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-700 dark:text-amber-200">' +
					"Gitalk 已接入，但还没有配置 GitHub OAuth App 的 clientID/clientSecret。" +
					"</div>";
			}

			function ensureGitalkAssets() {
				if (!document.getElementById(GITALK_CSS_ID)) {
					const link = document.createElement("link");
					link.id = GITALK_CSS_ID;
					link.rel = "stylesheet";
					link.href = "https://cdn.jsdelivr.net/npm/gitalk@1/dist/gitalk.css";
					document.head.appendChild(link);
				}

				if (window.Gitalk) {
					return Promise.resolve();
				}

				if (gitalkScriptPromise) {
					return gitalkScriptPromise;
				}

				gitalkScriptPromise = new Promise((resolve, reject) => {
					const existing = document.getElementById(GITALK_SCRIPT_ID);
					if (existing) {
						existing.addEventListener("load", resolve, { once: true });
						existing.addEventListener("error", reject, { once: true });
						return;
					}

					const script = document.createElement("script");
					script.id = GITALK_SCRIPT_ID;
					script.src =
						"https://cdn.jsdelivr.net/npm/gitalk@1/dist/gitalk.min.js";
					script.async = true;
					script.onload = resolve;
					script.onerror = reject;
					document.body.appendChild(script);
				});

				return gitalkScriptPromise;
			}

			function loadGitalk(container) {
				if (!commentsEnabled || container.dataset.loaded === "true") {
					return;
				}

				container.dataset.loaded = "true";
				if (!hasGitalkCredentials()) {
					showConfigWarning(container);
					return;
				}

				ensureGitalkAssets()
					.then(() => {
						container.innerHTML = "";
						const gitalk = new window.Gitalk({
							clientID: gitalkConfig.clientID,
							clientSecret: gitalkConfig.clientSecret,
							repo: gitalkConfig.repo,
							owner: gitalkConfig.owner,
							admin: gitalkConfig.admin,
							id: container.dataset.gitalkId,
							title: container.dataset.gitalkTitle,
							labels: gitalkConfig.labels,
							body: window.location.href,
							language: "zh-CN",
							distractionFreeMode: gitalkConfig.distractionFreeMode,
							proxy: gitalkConfig.proxy,
						});
						gitalk.render(container.id);
					})
					.catch(() => {
						container.innerHTML =
							'<div class="text-sm text-red-500">Gitalk 加载失败，请稍后重试。</div>';
					});
			}

			function initComments() {
				document.querySelectorAll(COMMENT_SELECTOR).forEach((container) => {
					const details = container.closest("details");
					if (details) {
						if (details.open) {
							loadGitalk(container);
						}
						if (details.dataset.commentsBound === "true") {
							return;
						}
						details.dataset.commentsBound = "true";
						details.addEventListener("toggle", () => {
							if (details.open) {
								loadGitalk(container);
							}
						});
						return;
					}

					loadGitalk(container);
				});
			}

			function updateGitalkTheme() {
				document.querySelectorAll(".gt-container").forEach((container) => {
					container.setAttribute("data-theme", getTheme());
				});
			}

			function initSorting() {
				const list = document.getElementById("moments-list");
				const controls = document.getElementById("moments-sort-controls");
				if (!list || !controls) {
					return;
				}

				controls.querySelectorAll(".moments-sort-btn").forEach((button) => {
					button.addEventListener("click", () => {
						const sort = button.dataset.sort || "desc";
						const cards = Array.from(list.children);
						cards.sort((a, b) => {
							const aTime = new Date(a.dataset.published || "").getTime();
							const bTime = new Date(b.dataset.published || "").getTime();
							return sort === "asc" ? aTime - bTime : bTime - aTime;
						});
						cards.forEach((card) => list.appendChild(card));
						controls
							.querySelectorAll(".moments-sort-btn")
							.forEach((item) => item.classList.remove("active"));
						button.classList.add("active");
					});
				});
			}

			function init() {
				initComments();
				initSorting();
			}

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", init);
			} else {
				init();
			}

			document.addEventListener("astro:page-load", init);
			document.addEventListener("mizuki:page:loaded", init);

			const themeObserver = new MutationObserver(updateGitalkTheme);
			themeObserver.observe(document.documentElement, {
				attributes: true,
				attributeFilter: ["class", "data-theme"],
			});
		})();
	</script>
</MainGridLayout>

<style>
	.moments-sort-btn.active {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
	}
</style>
